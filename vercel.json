{
  "version": 2,
  "name": "expense-tracker-pwa",
  "builds": [
    {
      "src": "build/web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/build/web/$1"
    }
  ],
  "installCommand": "chmod +x build.sh && ./build.sh",
  "buildCommand": "echo 'Build completed in install step'",
  "outputDirectory": "build/web",
  "framework": null
}